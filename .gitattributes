# Normalize text files to LF in the repository
* text=auto eol=lf

# Windows command scripts may keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.sqlite binary
*.db binary

# Model / vector database artifacts should normally not be committed,
# but mark common binary-like formats defensively
*.pkl binary
*.bin binary
*.npy binary
*.npz binary
*.parquet binary
